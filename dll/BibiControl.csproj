<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Builds the BibiControl mod as a standalone companion DLL that references the
    game's shipped assemblies. This is the easy-to-build path for testing.

    Override the game's Managed folder if it differs:
      dotnet build dll/BibiControl.csproj -c Release -p:GameManaged="C:\path\to\The Bibites_Data\Managed"
  -->

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <AssemblyName>BibiControl</AssemblyName>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GameManaged Condition="'$(GameManaged)' == ''">C:\Program Files (x86)\Steam\steamapps\common\The Bibites\The Bibites_Data\Managed</GameManaged>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="BibiControl\*.cs" />
  </ItemGroup>

  <!-- .NET Framework 4.7.2 reference assemblies (downloaded; nothing installed system-wide). -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies.net472" Version="1.0.3" PrivateAssets="all" />
  </ItemGroup>

  <!-- Game + Unity + Newtonsoft assemblies from the install. Private=false: do not copy them to output. -->
  <ItemGroup>
    <Reference Include="BibitesAssembly">
      <HintPath>$(GameManaged)\BibitesAssembly.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(GameManaged)\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>$(GameManaged)\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Newtonsoft.Json">
      <HintPath>$(GameManaged)\Newtonsoft.Json.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
